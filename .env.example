# --- Anthropic credentials (one of these is required) ----------------------
#
# Native Anthropic API:
# ANTHROPIC_API_KEY=sk-ant-...
#
# OpenRouter (or any Anthropic-compatible proxy):
# IMPORTANT: ANTHROPIC_BASE_URL must NOT include a trailing /v1 — Claude
# Code's CLI appends /v1/messages itself. For OpenRouter use:
# ANTHROPIC_AUTH_TOKEN=sk-or-v1-...
# ANTHROPIC_BASE_URL=https://openrouter.ai/api

# --- Model + server tuning (optional) --------------------------------------
# MODEL=claude-sonnet-4-6                # native Anthropic
# MODEL=anthropic/claude-haiku-4.5       # OpenRouter (vendor-prefixed)
# PORT=8020
# ALLOWED_ORIGINS=http://localhost:3000  # comma-separated, or "*" for dev

# --- Optional skills -------------------------------------------------------
# Setting GITHUB_TOKEN enables the demo's github skill (shells out to `gh`).
# GITHUB_TOKEN=
