{
  "name": "agent-react",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "description": "React/Next-side runtime for an agent built on agent-server. Builds a json-render web registry from your widgets, exposes <WidgetSurface> and <ChatShell>, and handles the AG-UI client loop.",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./markdown": "./src/markdown.ts"
  },
  "sideEffects": false,
  "scripts": {
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "agent-core": "workspace:*",
    "@ag-ui/client": "^0.0.53",
    "@ag-ui/core": "^0.0.53",
    "@json-render/core": "^0.19.0",
    "@json-render/react": "^0.19.0",
    "react-markdown": "^10.1.0"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@types/react": "^19",
    "react": "^19.2.4",
    "typescript": "^5.5.0",
    "zod": "^4.0.0"
  }
}
