{
  "name": "agent-pdf",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "description": "PDF rendering for agent widget catalogs. Mounts each Widget's renderPdf into a json-render PDF registry and exposes a Next-friendly POST handler factory.",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./route": "./src/route.ts",
    "./primitives": "./src/primitives.tsx"
  },
  "scripts": {
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "agent-core": "workspace:*",
    "@json-render/core": "^0.19.0",
    "@json-render/react-pdf": "^0.19.0"
  },
  "peerDependencies": {
    "@react-pdf/renderer": "^4.5.0",
    "react": "^19.0.0"
  },
  "devDependencies": {
    "@react-pdf/renderer": "^4.5.1",
    "@types/react": "^19",
    "react": "^19.2.4",
    "typescript": "^5.5.0"
  }
}
